{
  "name": "notes-app-backend",
  "version": "1.0.0",
  "description": "Backend for notes application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test mocha --require test/setup.js --timeout 10000 --exit --recursive test/**/*.test.js",
    "test:watch": "cross-env NODE_ENV=test mocha --require test/setup.js --timeout 10000 --watch --recursive test/**/*.test.js",
    "test:debug": "cross-env NODE_ENV=test mocha --require test/setup.js --timeout 30000 --recursive test/**/*.test.js --inspect-brk"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "mongoose": "^7.8.7",
    "multer": "^2.0.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "validator": "^13.15.15"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "chai-http": "^4.4.0",
    "cross-env": "^10.1.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.1",
    "nyc": "^15.1.0",
    "supertest": "^6.3.3"
  }
}
